{
    "name": "vantura-digital/amw-wholesale",
    "description": "AMW-internal B2B wholesale plugin for WooCommerce.",
    "type": "wordpress-plugin",
    "license": "proprietary",
    "require": {
        "php": ">=8.1",
        "dompdf/dompdf": "^3.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5"
    },
    "autoload": {
        "psr-4": {}
    },
    "autoload-dev": {
        "psr-4": {
            "AMW\\Wholesale\\Tests\\": "tests/"
        }
    },
    "config": {
        "sort-packages": true,
        "optimize-autoloader": true,
        "allow-plugins": {}
    },
    "scripts": {
        "test": "vendor/bin/phpunit --colors=never"
    }
}
